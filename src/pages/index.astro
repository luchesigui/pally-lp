      <div class="container">
        <div class="glass-card cta-box">
          <h2 class="cta-heading">Pronto para a sua próxima viagem?</h2>
          <p class="cta-desc">
            Acesse o Pally e tenha o seu próprio Companheiro de Viagem
            orientando cada passo do seu caminho de forma tranquila e
            inteligente direto no seu navegador.
          </p>

          <!-- Form de leads B2C -->
          <div class="lead-form-wrapper">
            <h3 class="lead-form-title">Faça parte da nossa lista de espera</h3>
            <form class="lead-form" id="contact-form" novalidate>
              <div class="form-row-2">
                <div class="form-group">
                  <label class="form-label" for="form-name">Nome</label>
                  <input
                    class="form-input"
                    type="text"
                    id="form-name"
                    placeholder="Seu nome"
                    required
                    autocomplete="name"
                  />
                </div>
                <div class="form-group">
                  <label class="form-label" for="form-email">E-mail</label>
                  <input
                    class="form-input"
                    type="email"
                    id="form-email"
                    placeholder="seu@email.com"
                    required
                    autocomplete="email"
                  />
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="form-dest"
                  >Próximo destino planejado</label
                >
                <input
                  class="form-input"
                  type="text"
                  id="form-dest"
                  placeholder="Ex: Paris, Tóquio"
                  required
                />
              </div>

              <button class="btn btn-primary form-submit-btn" type="submit">
                Entrar na Lista de Espera
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>

