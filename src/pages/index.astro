        function renderPreviewCards(situationKey) {
          const data = previewData[situationKey];
          previewCardsStack.innerHTML = ""; // Limpar antigos

          data.cards.forEach((card, index) => {
            const cardEl = document.createElement("div");
            cardEl.className = "app-interactive-card";
            cardEl.setAttribute("data-index", index);

            cardEl.innerHTML = `
            <div class="card-body">
              <div class="card-name">${card.name}</div>
              <div class="card-desc">${card.desc}</div>
            </div>
            <div class="card-time">
              <span>🚶 ${card.walkTime}</span>
            </div>
          `;

            previewCardsStack.appendChild(cardEl);
          });
        }

        // Reset system to original suggestions list state
        function resetToSuggestions(animated = true) {
          const situationKey = document
            .querySelector(".time-btn.active")
            .getAttribute("data-situation");

          const activeWrapper = document.querySelector(
            `.map-preview-layer.active .map-wrapper`,
          );
          if (activeWrapper) {
            activeWrapper.style.transition = animated
              ? "transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)"
              : "none";
            activeWrapper.style.transform = "scale(1.35) translate(0%, 0%)";

            activeWrapper.querySelectorAll(".preview-pin").forEach((p) => {
              p.classList.remove("active");
            });

            const routeLine = activeWrapper.querySelector(
              ".preview-route-line",
            );
            if (routeLine) {
              routeLine.classList.remove("active");
            }
          }

          // Reset cards stacked and detailed card
          previewCardsStack.classList.remove("collapsed");
          previewDetailCard.classList.remove("active");
          previewRouteNotification.classList.remove("active");

          // Reset bubbles text and opacity
          previewPallyBubble.style.opacity = "1";
          previewPallyBubble.style.transform = "translateY(0)";

          activePreviewIndex = null;
        }

