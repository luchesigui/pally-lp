    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        /* ==========================================================================
         A. Menu Sanduíche Mobile
         ========================================================================== */
        const burgerToggle = document.getElementById("burger-toggle");
        const navMenu = document.getElementById("nav-menu");

        burgerToggle.addEventListener("click", () => {
          const isExpanded =
            burgerToggle.getAttribute("aria-expanded") === "true";
          burgerToggle.setAttribute("aria-expanded", !isExpanded);
          navMenu.classList.toggle("active");

          // Modifica traços do sanduíche
          const spans = burgerToggle.querySelectorAll("span");
          if (!isExpanded) {
            spans[0].style.transform = "rotate(45deg) translate(5px, 5px)";
            spans[1].style.opacity = "0";
            spans[2].style.transform = "rotate(-45deg) translate(5px, -5px)";
          } else {
            spans[0].style.transform = "none";
            spans[1].style.opacity = "1";
            spans[2].style.transform = "none";
          }
        });

        // Fecha o menu ao clicar em um link
        document.querySelectorAll(".nav-link").forEach((link) => {
          link.addEventListener("click", () => {
            navMenu.classList.remove("active");
            burgerToggle.setAttribute("aria-expanded", "false");
            const spans = burgerToggle.querySelectorAll("span");
            spans[0].style.transform = "none";
            spans[1].style.opacity = "1";
            spans[2].style.transform = "none";
          });
        });

        /* ==========================================================================
         B. Fallback para Shrinking Header no Scroll (Firefox e navegadores legados)
         ========================================================================== */
        if (
          !CSS.supports(
            "(animation-timeline: scroll()) and (animation-range: 0% 100%)",
          )
        ) {
          const header = document.querySelector(".nav-header");
          window.addEventListener("scroll", () => {
            if (window.scrollY > 50) {
              header.style.height = "64px";
              header.style.background = "rgba(255, 255, 255, 0.9)";
              header.style.boxShadow = "0 10px 30px rgba(0, 0, 0, 0.04)";
              header.style.borderBottomColor = "rgba(0, 180, 216, 0.1)";
            } else {
              header.style.height = "80px";
              header.style.background = "rgba(250, 250, 250, 0.7)";
              header.style.boxShadow = "none";
              header.style.borderBottomColor = "rgba(0, 180, 216, 0.04)";
            }
          });
        }

        /* ==========================================================================
         C. Interação Especial no Hero Phone Mockup (Unified transformations)
         ========================================================================== */
        const mapWrapper = document.getElementById("hero-map-wrapper");
        const pins = document.querySelectorAll("#hero-map-wrapper .map-pin");
        const heroCards = document.querySelectorAll(
          ".app-cards-container .app-interactive-card",
        );
        const cardsContainer = document.querySelector(".app-cards-container");

        const routeLine = document.getElementById("route-line");
        const detailCard = document.getElementById("poi-detail-card");
        const routeNotification = document.getElementById(
          "hero-route-notification",
        );
        const btnPlotRoute = document.getElementById("btn-plot-route");

        // Increased scale values to guarantee full coverage of the map canvas (avoiding white gaps)
        const heroTransforms = [
          "scale(1.45) translate(5%, 12%)", // Pin 1: Parque Ueno
          "scale(1.55) translate(22%, -12%)", // Pin 2: Café Kitsuné
          "scale(1.45) translate(-15%, 15%)", // Pin 3: teamLab Borderless
        ];

        let simTimeout = null;

        function runSimulation() {
          // Step 0: Initial state - No card selected, no active pins, general map view
          cardsContainer.classList.remove("collapsed");
          detailCard.classList.remove("active");
          routeNotification.classList.remove("active");
          if (routeLine) routeLine.classList.remove("active");

          // General map view centered, scale 1.35 to prevent gaps
          mapWrapper.style.transform = "scale(1.35) translate(0%, 0%)";
          pins.forEach((p) => p.classList.remove("active"));
          heroCards.forEach((c) => c.classList.remove("selected"));

          // Wait 3.5 seconds in the initial state
          simTimeout = setTimeout(() => {
            // Step 1: Select teamLab Borderless (Card 2) and perform click animation
            heroCards[2].classList.add("selected");
            pins[2].classList.add("active");
            mapWrapper.style.transform = heroTransforms[2];

            // Leve animação de clique no card
            heroCards[2].style.transform = "scale(0.96)";
            heroCards[2].style.transition = "transform 0.15s ease";
            setTimeout(() => {
              heroCards[2].style.transform = "";
            }, 150);

            // Let click animation finish, then start hiding recommendation cards
            simTimeout = setTimeout(() => {
              cardsContainer.classList.add("collapsed");

              // After 0.3 seconds (300ms) delay, slide up the details card
              simTimeout = setTimeout(() => {
                detailCard.classList.add("active");

                simTimeout = setTimeout(() => {
                  // Step 2b: Simulate clicking "Traçar Rota"
                  if (btnPlotRoute) {
                    btnPlotRoute.classList.add("clicked");
                    setTimeout(
                      () => btnPlotRoute.classList.remove("clicked"),
                      200,
                    );
                  }

                  simTimeout = setTimeout(() => {
                    // Step 3: Detail card slides down, Zoom out map to show route, Route draws, Notification appears
                    detailCard.classList.remove("active");

                    // Zoom out to fit route (coordinates 50%,50% and 75%,22%). Scale 1.35 prevents gaps.
                    mapWrapper.style.transform =
                      "scale(1.35) translate(-12.5%, 14%)";

                    pins.forEach((p) => p.classList.remove("active")); // remove active status from others
                    pins[2].classList.add("active"); // keep destination pin active

                    if (routeLine) routeLine.classList.add("active");
                    routeNotification.classList.add("active");

                    simTimeout = setTimeout(() => {
                      // Loop again
                      runSimulation();
                    }, 6000); // Wait 6 seconds showing the plotted route
                  }, 800); // Click reaction delay
                }, 3000); // Show details for 3 seconds
              }, 300); // Wait 0.3 seconds before sliding up the details card
            }, 200); // Collapse recommendation cards 200ms after selection
          }, 3500); // Initial general view for 3.5 seconds
        }

        // Start the simulation
        runSimulation();

        /* ==========================================================================
         D. Monitoramento do Progresso da Linha do Tempo no Scroll (Intersection Observer)
         ========================================================================== */
        const timelineSection = document.getElementById("como-funciona");
        const timelineProgressBar = document.getElementById(
          "timeline-progress-bar",
        );
        const timelineItems = document.querySelectorAll(".timeline-item");

        const timelineObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("active");
              }
            });
          },
          {
            threshold: 0.35,
            rootMargin: "0px 0px -10% 0px",
          },
        );

        timelineItems.forEach((item) => timelineObserver.observe(item));

        // Atualização do preenchimento da barra de progresso no scroll
        window.addEventListener("scroll", () => {
          if (!timelineSection || !timelineProgressBar) return;

          const rect = timelineSection.getBoundingClientRect();
          const sectionHeight = rect.height;
          const viewportHeight = window.innerHeight;

          // Porcentagem de progresso de visualização da seção
          const visibleDistance = viewportHeight * 0.8;
          const totalScrollable = sectionHeight + visibleDistance - 150;
          let scrollRatio = (visibleDistance - rect.top) / totalScrollable;

          scrollRatio = Math.max(0, Math.min(scrollRatio, 1));
          timelineProgressBar.style.height = `${scrollRatio * 100}%`;
        });

        /* ==========================================================================
         E. Preview Interativo Dia / Tarde / Noite (B2C Slim Cards and notifications)
         ========================================================================== */
        const timeButtons = document.querySelectorAll(".time-btn");
        const timeDesc = document.getElementById("time-description");
        const timeTag = document.getElementById("preview-time-tag");
