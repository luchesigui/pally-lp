          if (activeWrapper) {
            activeWrapper.style.transition =
              "transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)";
            activeWrapper.style.transform = cardData.mapTransform;

            activeWrapper.querySelectorAll(".preview-pin").forEach((p) => {
              const pIndex = parseInt(p.getAttribute("data-index"), 10);
              if (pIndex === index) {
                p.classList.add("active");
              } else {
                p.classList.remove("active");
              }
            });

            // Clear route visual state
            const routeLine = activeWrapper.querySelector(
              ".preview-route-line",
            );
            if (routeLine) {
              routeLine.classList.remove("active");
            }
          }

          // Slide Up detailed card
          previewDetailCard.classList.add("active");
        }

        // Plot Route and show banner
        function plotPreviewRoute(index) {
          const situationKey = document
            .querySelector(".time-btn.active")
            .getAttribute("data-situation");
          const cardData = previewData[situationKey].cards[index];

          // Slide down detailed card
          previewDetailCard.classList.remove("active");

          // Draw Route line
          const activeWrapper = document.querySelector(
            `.map-preview-layer.active .map-wrapper`,
          );
          if (activeWrapper) {
            const routeLine = activeWrapper.querySelector(
              ".preview-route-line",
            );
            if (routeLine) {
              routeLine.setAttribute("d", cardData.routePath);
              // Force reflow
              routeLine.getBoundingClientRect();
              routeLine.classList.add("active");
            }
          }

          // Show Route notification toast
          previewRouteDesc.textContent = `${cardData.walkTime} de caminhada até ${cardData.name}`;
          previewRouteNotification.classList.add("active");
        }

        function updatePreviewSection(situationKey) {
          // Atualizar botões de toggle
          timeButtons.forEach((btn) => {
            if (btn.getAttribute("data-situation") === situationKey) {
              btn.classList.add("active");
              btn.setAttribute("aria-selected", "true");
            } else {
              btn.classList.remove("active");
              btn.setAttribute("aria-selected", "false");
            }
          });

          // Actualizar textos e períodos
          const data = previewData[situationKey];
          timeDesc.innerHTML = data.desc;
          timeTag.textContent = data.status;
          bubblePreviewText.textContent = data.bubble;
          previewPallyBubbleIcon.textContent = data.emoji;

          // Trocar camadas de mapas com transição
          document.querySelectorAll(".map-preview-layer").forEach((layer) => {
            layer.classList.remove("active");
          });
          document
            .getElementById(`map-layer-${situationKey}`)
            .classList.add("active");

          // Re-renderizar cards e reiniciar estados de zoom/detalhe
          renderPreviewCards(situationKey);
          resetToSuggestions(false);
        }

        // Event listener dos botões do período/situação
        timeButtons.forEach((btn) => {
          btn.addEventListener("click", () => {
            const situationKey = btn.getAttribute("data-situation");
            updatePreviewSection(situationKey);
          });
        });

        // Clique nos cards dinâmicos do preview abre detalhe
        previewCardsStack.addEventListener("click", (e) => {
          const card = e.target.closest(".app-interactive-card");
          if (!card) return;

          const index = parseInt(card.getAttribute("data-index"), 10);
          showDetailCard(index);
        });

        // Clique nos pins do mapa ativo abre detalhe
        document
          .getElementById("preview-map-container")
          .addEventListener("click", (e) => {
            const pin = e.target.closest(".preview-pin");
            if (!pin) return;

            const index = parseInt(pin.getAttribute("data-index"), 10);
            showDetailCard(index);
          });

        // Event listener do botão "Traçar Rota" no detalhe do preview
        previewBtnPlotRoute.addEventListener("click", () => {
          if (activePreviewIndex !== null) {
            plotPreviewRoute(activePreviewIndex);
          }
        });

        // Fechar detalhe clicando fora do card/pin/sugestão
        const previewPhone = document.getElementById("preview-phone");
        previewPhone.addEventListener("click", (e) => {
          const isDetailActive = previewDetailCard.classList.contains("active");
          const isRouteActive =
            previewRouteNotification.classList.contains("active");

          if (isDetailActive || isRouteActive) {
            const clickedCard = e.target.closest("#preview-detail-card");
            const clickedPin = e.target.closest(".preview-pin");
            const clickedBottomCard = e.target.closest(".app-interactive-card");
            const clickedRouteNotif = e.target.closest(
              "#preview-route-notification",
            );

            if (
              !clickedCard &&
              !clickedPin &&
              !clickedBottomCard &&
              !clickedRouteNotif
            ) {
              resetToSuggestions(true);
            }
          }
        });

        // Inicializa o primeiro período (Clima / Chuva)
        updatePreviewSection("chuva");

        /* ==========================================================================
         F. Envio de Formulário com Validação Customizada e Modal de Sucesso (B2C Only)
         ========================================================================== */
        const contactForm = document.getElementById("contact-form");
        const successModal = document.getElementById("success-modal");
        const successModalMsg = document.getElementById("success-modal-msg");
        const closeModalBtn = document.getElementById("close-modal-btn");

        contactForm.addEventListener("submit", async (e) => {
          e.preventDefault();

          let isFormValid = true;
          const inputs = contactForm.querySelectorAll(".form-input");

          inputs.forEach((input) => {
            if (!input.checkValidity()) {
              isFormValid = false;
              input.style.borderColor = "#EF4444";
              input.style.boxShadow = "0 0 0 3px rgba(239, 68, 68, 0.15)";
            } else {
              input.style.borderColor = "rgba(0, 180, 216, 0.15)";
              input.style.boxShadow = "none";
            }
          });

          if (isFormValid) {
            const nameVal = document.getElementById("form-name").value;
            const emailVal = document.getElementById("form-email").value;
            const destVal = document.getElementById("form-dest").value;

            const submitBtn = contactForm.querySelector(".form-submit-btn");
            const originalBtnText = submitBtn.textContent;
            submitBtn.textContent = "Enviando...";
            submitBtn.disabled = true;

            try {
              const response = await fetch("/api/subscribe", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ name: nameVal, email: emailVal, destination: destVal }),
              });

              if (response.ok) {
                successModalMsg.textContent = `Olá ${nameVal}, confirmamos sua inscrição! Enviaremos novidades e o link de acesso antecipado para a sua viagem para ${destVal} no e-mail ${emailVal}.`;
                successModal.classList.add("active");
                contactForm.reset();
              } else {
                alert("Erro ao processar sua inscrição. Tente novamente em instantes.");
              }
            } catch {
              alert("Erro de conexão. Verifique sua internet e tente novamente.");
            } finally {
              submitBtn.textContent = originalBtnText;
              submitBtn.disabled = false;
            }
          }
        });

        // Fecha o modal de sucesso
        closeModalBtn.addEventListener("click", () => {
          successModal.classList.remove("active");
        });

        // Reseta cores de erro conforme usuário digita corretamente
        contactForm.querySelectorAll(".form-input").forEach((input) => {
          input.addEventListener("input", () => {
            if (input.checkValidity()) {
              input.style.borderColor = "rgba(0, 180, 216, 0.15)";
              input.style.boxShadow = "none";
            }
          });
        });

        /* ==========================================================================
         G. Micro-interação Hover no Logo (Rotação orientada ao cursor)
         ========================================================================== */
        document.querySelectorAll(".nav-logo:not(.nav-logo--static)").forEach((logo) => {
          const svg = logo.querySelector("svg");
          if (!svg) return;

          logo.addEventListener("mousemove", (e) => {
            const rect = svg.getBoundingClientRect();

            // Calculate visual center of the SVG
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;

            // Distance from center to cursor
            const dx = e.clientX - centerX;
            const dy = e.clientY - centerY;

            // Calculate angle in degrees
            const angleRad = Math.atan2(dy, dx);
            let angleDeg = angleRad * (180 / Math.PI);

            // Calibration offset: since the pointing part is already rotated ~30deg to the right,
            // we offset the target rotation angle to align that part with the cursor.
            // +30 degrees translates the visual center-point of the logo to face the cursor.
            const ANGLE_OFFSET = 30;
            angleDeg += ANGLE_OFFSET;

            // Set custom property to rotate the SVG
            svg.style.setProperty("--logo-rotation", `${angleDeg}deg`);
          });

          logo.addEventListener("mouseleave", () => {
            // Smoothly snap back to 0 degrees
            svg.style.setProperty("--logo-rotation", "0deg");
          });
        });
      });
    </script>
  </body>
</html>
