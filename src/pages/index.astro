---
import '../styles/global.css';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Pally — O companheiro de viagem proativo que transforma sua experiência de viagem com mapas inteligentes e sugestões em tempo real."
    />
    <title>Pally — Seu Companheiro de Viagem Proativo</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Elementos Ambientais de Background -->
    <div class="bg-grid" aria-hidden="true"></div>
    <div class="bg-blob blob-1" aria-hidden="true"></div>
    <div class="bg-blob blob-2" aria-hidden="true"></div>
    <div class="bg-blob blob-3" aria-hidden="true"></div>

    <!-- ==========================================================================
       1. Nav Header (Glassmorphic)
       ========================================================================== -->
    <header class="nav-header">
      <div class="container nav-container">
        <a href="#" class="nav-logo" aria-label="Voltar ao topo">
          <!-- Novo SVG Logo do Pallas (#00B4D8) -->
          <svg
            viewBox="0 0 444 465"
            width="32"
            height="32"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <defs>
              <linearGradient
                id="logo-grad-site-header"
                x1="0%"
                y1="0%"
                x2="100%"
                y2="100%"
              >
                <stop offset="0%" stop-color="#00B4D8" />
                <stop offset="100%" stop-color="#7209B7" />
              </linearGradient>
            </defs>
            <g
              fill="url(#logo-grad-site-header)"
              transform="translate(0,465) scale(0.1,-0.1)"
            >
              <path
                d="M2050 3934 c-264 -33 -549 -138 -762 -281 -619 -415 -912 -1172 -732 -1888 106 -420 379 -800 746 -1039 383 -249 861 -339 1308 -245 138 29 239 64 379 130 202 96 315 174 470 323 214 208 350 417 440 679 130 376 133 756 10 1135 l-21 62 -56 -51 c-69 -61 -195 -125 -277 -140 -90 -17 -86 -15 -74 -46 24 -64 50 -216 55 -333 17 -335 -112 -674 -353 -930 -185 -197 -445 -339 -708 -385 -116 -20 -325 -21 -437 -1 -317 57 -610 234 -800 483 -181 236 -271 497 -271 788 0 345 133 665 378 910 363 364 911 474 1396 280 13 -5 21 11 43 78 31 95 87 187 158 261 27 28 48 51 48 53 0 7 -117 54 -204 82 -183 59 -273 73 -496 76 -113 2 -221 1 -240 -1z"
              />
              <path
                d="M3314 3716 c-86 -20 -159 -59 -224 -122 -103 -98 -146 -209 -138 -361 5 -82 10 -103 42 -169 175 -353 665 -351 834 3 36 77 37 80 37 198 0 118 -1 121 -37 195 -37 76 -111 161 -173 199 -96 58 -234 81 -341 57z"
              />
            </g>
          </svg>
          <span>Pally</span>
        </a>

        <nav class="nav-menu" id="nav-menu" aria-label="Menu principal">
          <a href="#features" class="nav-link">Recursos</a>
          <a href="#como-funciona" class="nav-link">Como funciona</a>
          <a href="#preview" class="nav-link">Demonstração</a>
        </nav>

        <div class="nav-actions">
          <a href="#waitlist" class="btn btn-secondary">Acessar App</a>
        </div>

        <button
          class="burger-menu"
          id="burger-toggle"
          aria-label="Abrir menu de navegação"
          aria-expanded="false"
          aria-controls="nav-menu"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>
    </header>

    <!-- ==========================================================================
       2. Hero Section (Visual do App com Mapa + 3 Cards)
       ========================================================================== -->
    <section class="hero-section">
      <div class="container hero-grid">
        <div class="hero-content">
          <div class="hero-badge">
            <span class="badge-dot"></span>
            <span>Pally: Seu Companheiro de Viagem</span>
          </div>
          <h1 class="hero-title">
            Não planeje sua viagem. <strong>Viva sua viagem.</strong>
          </h1>
          <p class="hero-subtitle">
            Pally é um companheiro de viagem proativo (mobile-first) que
            acompanha seus passos. Sem chatbots cansativos. Uma interface visual
            inteligente que lê seu contexto e sugere o que fazer a seguir.
          </p>
          <div class="hero-actions">
            <a href="#waitlist" class="btn btn-primary">Acessar grátis</a>
            <a href="#preview" class="btn btn-secondary">Ver demonstração</a>
          </div>
        </div>

        <div class="hero-visual">
          <!-- Phone Mockup - Showing only the phone, centered and styled cleanly, no external float elements -->
          <div class="phone-mockup">
            <div class="phone-island"></div>
            <div class="phone-screen">
              <div class="app-header">
                <div class="app-logo">
                  <svg
                    viewBox="0 0 444 465"
                    width="24"
                    height="24"
                    xmlns="http://www.w3.org/2000/svg"
                    aria-hidden="true"
                    style="flex-shrink: 0"
                  >
                    <defs>
                      <linearGradient
                        id="logo-grad-mobile"
                        x1="0%"
                        y1="0%"
                        x2="100%"
                        y2="100%"
                      >
                        <stop offset="0%" stop-color="#00B4D8" />
                        <stop offset="100%" stop-color="#7209B7" />
                      </linearGradient>
                    </defs>
                    <g
                      fill="url(#logo-grad-mobile)"
                      transform="translate(0,465) scale(0.1,-0.1)"
                    >
                      <path
                        d="M2050 3934 c-264 -33 -549 -138 -762 -281 -619 -415 -912 -1172 -732 -1888 106 -420 379 -800 746 -1039 383 -249 861 -339 1308 -245 138 29 239 64 379 130 202 96 315 174 470 323 214 208 350 417 440 679 130 376 133 756 10 1135 l-21 62 -56 -51 c-69 -61 -195 -125 -277 -140 -90 -17 -86 -15 -74 -46 24 -64 50 -216 55 -333 17 -335 -112 -674 -353 -930 -185 -197 -445 -339 -708 -385 -116 -20 -325 -21 -437 -1 -317 57 -610 234 -800 483 -181 236 -271 497 -271 788 0 345 133 665 378 910 363 364 911 474 1396 280 13 -5 21 11 43 78 31 95 87 187 158 261 27 28 48 51 48 53 0 7 -117 54 -204 82 -183 59 -273 73 -496 76 -113 2 -221 1 -240 -1z"
                      />
                      <path
                        d="M3314 3716 c-86 -20 -159 -59 -224 -122 -103 -98 -146 -209 -138 -361 5 -82 10 -103 42 -169 175 -353 665 -351 834 3 36 77 37 80 37 198 0 118 -1 121 -37 195 -37 76 -111 161 -173 199 -96 58 -234 81 -341 57z"
                      />
                    </g>
                  </svg>
                  <div class="app-logo-text">Pally</div>
                </div>
                <div class="app-status">🌤️ 22°C</div>
              </div>

              <!-- Interactive Map Container -->
              <div class="app-map-canvas" id="app-map-container">
                <!-- Map wrapper grouping streets and pins to transform them together -->
                <div class="map-wrapper" id="hero-map-wrapper">
                  <!-- SVG do mapa com ruas e lagos de Tóquio simplificados -->
                  <svg
                    viewBox="0 0 400 400"
                    xmlns="http://www.w3.org/2000/svg"
                    preserveAspectRatio="xMidYMid slice"
                  >
                    <!-- Fundo / Terra -->
                    <rect width="400" height="400" fill="#FAF6EE" />

                    <!-- Lago / Rio Sumida -->
                    <path
                      d="M 280,0 Q 240,150 350,300 T 400,400 L 400,0 Z"
                      fill="#C5E2F6"
                    />

                    <!-- Áreas verdes de parques -->
                    <circle cx="160" cy="120" r="45" fill="#D2E8D4" />
                    <!-- Parque Ueno -->
                    <circle cx="90" cy="270" r="30" fill="#D2E8D4" />
                    <!-- Café Kitsuné -->
                    <rect
                      x="250"
                      y="70"
                      width="80"
                      height="40"
                      rx="15"
                      fill="#D2E8D4"
                    />

                    <!-- Ruas -->
                    <path
                      d="M 0,100 L 400,100 M 0,220 L 400,220 M 0,330 L 400,330"
                      stroke="#FFFFFF"
                      stroke-width="6"
                      fill="none"
                    />
                    <path
                      d="M 120,0 L 120,400 M 240,0 L 240,400 M 340,0 L 340,400"
                      stroke="#FFFFFF"
                      stroke-width="6"
                      fill="none"
                    />
                    <path
                      d="M 0,0 L 400,400"
                      stroke="#FFFFFF"
                      stroke-width="4"
                      stroke-dasharray="8,8"
                      fill="none"
                      opacity="0.6"
                    />
                  </svg>

                  <!-- Overlay SVG for percentage-based route line alignment to prevent offset/crops -->
                  <svg
                    viewBox="0 0 100 100"
                    preserveAspectRatio="none"
                    style="
                      position: absolute;
                      top: 0;
                      left: 0;
                      width: 100%;
                      height: 100%;
                      pointer-events: none;
                      z-index: 2;
                    "
                  >
                    <path
                      class="route-line"
                      id="route-line"
                      d="M 50,50 Q 63,32 75,22"
                      stroke="#00B4D8"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      fill="none"
                    />
                  </svg>

                  <!-- User coordinate -->
                  <div class="user-position" aria-label="Sua localização"></div>

                  <!-- Interactive Pins -->
                  <div
                    class="map-pin active"
                    id="pin-1"
                    data-index="0"
                    aria-label="Pino 1: Parque Ueno"
                  >
                    <svg viewBox="0 0 24 24">
                      <path
                        d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"
                        fill="#00B4D8"
                      />
                    </svg>
                  </div>

                  <div
                    class="map-pin"
                    id="pin-2"
                    data-index="1"
                    aria-label="Pino 2: Café Kitsuné"
                  >
                    <svg viewBox="0 0 24 24">
                      <path
                        d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"
                        fill="#00B4D8"
                      />
                    </svg>
                  </div>

                  <div
                    class="map-pin"
                    id="pin-3"
                    data-index="2"
                    aria-label="Pino 3: teamLab Borderless"
                  >
                    <svg viewBox="0 0 24 24">
                      <path
                        d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"
                        fill="#00B4D8"
                      />
                    </svg>
                  </div>
                </div>
              </div>

              <!-- Top Notification for Plotted Route -->
              <div class="app-route-notification" id="hero-route-notification">
                <div class="route-notif-icon">🧭</div>
                <div class="route-notif-body">
                  <div class="route-notif-title">Rota traçada!</div>
                  <div class="route-notif-desc">
                    12 min de caminhada até teamLab Borderless
                  </div>
                </div>
              </div>

              <!-- Detail Card (hidden by default) -->
              <div class="app-detail-card" id="poi-detail-card">
                <div class="detail-header">
                  <span class="detail-category">Arte Digital</span>
                  <span class="detail-rating">⭐ 4.9 (2.4k)</span>
                </div>
                <div class="detail-name">teamLab Borderless</div>
                <div class="detail-desc">
                  Um mundo sem fronteiras criado por computação gráfica em tempo
                  real. Arte tridimensional imersiva e interativa.
                </div>
                <div class="detail-meta">
                  <div class="detail-meta-item">
                    <span class="detail-meta-label">Distância</span>
                    <span class="detail-meta-val">🚶 12 min (1.2 km)</span>
                  </div>
                  <div class="detail-meta-item">
                    <span class="detail-meta-label">Funcionamento</span>
                    <span class="detail-meta-val">Aberto (10h - 21h)</span>
                  </div>
                </div>
                <div class="detail-actions">
                  <button class="btn-detail btn-ticket" id="btn-view-ticket">
                    <span>🎟️ Ver Ingresso</span>
                  </button>
                  <button class="btn-detail btn-route" id="btn-plot-route">
                    <span>Traçar Rota</span>
                  </button>
                </div>
              </div>

              <!-- Contextual Cards Container (All 3 Cards stacked at bottom) -->
              <div class="app-cards-container">
                <!-- Card 0: Parque Ueno -->
                <div
                  class="app-interactive-card selected"
                  id="hero-card-0"
                  data-index="0"
                >
                  <div class="card-body">
                    <div class="card-name">Parque Ueno</div>
                    <div class="card-desc">
                      Caminhada sob as cerejeiras e templos históricos.
                    </div>
                  </div>
                  <div class="card-time">
                    <span>🚶 10 min</span>
                  </div>
                </div>

                <!-- Card 1: Café Kitsuné -->
                <div
                  class="app-interactive-card"
                  id="hero-card-1"
                  data-index="1"
                >
                  <div class="card-body">
                    <div class="card-name">Café Kitsuné</div>
                    <div class="card-desc">
                      Matcha latte artesanal e ambiente descontraído.
                    </div>
                  </div>
                  <div class="card-time">
                    <span>🚶 5 min</span>
                  </div>
                </div>

                <!-- Card 2: teamLab Borderless -->
                <div
                  class="app-interactive-card"
                  id="hero-card-2"
                  data-index="2"
                >
                  <div class="card-body">
                    <div class="card-name">teamLab Borderless</div>
                    <div class="card-desc">
                      Exposição de arte digital imersiva e interativa.
                    </div>
                  </div>
                  <div class="card-time">
                    <span>🚶 12 min</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==========================================================================
       3. O Que É Section
       ========================================================================== -->
    <section class="what-is-section" id="oque-e">
      <div class="container">
        <div class="section-header">
          <span class="section-tagline">O Conceito</span>
          <h2>O que é um "Companheiro de Viagem"?</h2>
          <p class="section-description">
            Pally não quer conversar com você por texto por horas. Ele é uma
            inteligência visual silenciosa que entende onde você está, que horas
            são e o que você prefere — exibindo opções diretamente na tela.
          </p>
        </div>

        <div class="concept-grid">
          <div class="concept-card chatbot-card">
            <h3 class="concept-card-title">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                />
              </svg>
              Assistentes / Chatbots comuns
            </h3>
            <div class="concept-body">
              <div class="concept-item">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#EF4444"
                  stroke-width="2"
                >
                  <circle cx="12" cy="12" r="10" />
                  <line x1="15" y1="9" x2="9" y2="15" />
                  <line x1="9" y1="9" x2="15" y2="15" />
                </svg>
                <span
                  >Exige digitação constante e leitura de longos parágrafos
                  explicativos.</span
                >
              </div>
              <div class="concept-item">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#EF4444"
                  stroke-width="2"
                >
                  <circle cx="12" cy="12" r="10" />
                  <line x1="15" y1="9" x2="9" y2="15" />
                  <line x1="9" y1="9" x2="15" y2="15" />
                </svg>
                <span
                  >Reações passivas. Só ajuda quando você inicia a conversa e
                  faz perguntas.</span
                >
              </div>
              <div class="concept-item">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#EF4444"
                  stroke-width="2"
                >
                  <circle cx="12" cy="12" r="10" />
                  <line x1="15" y1="9" x2="9" y2="15" />
                  <line x1="9" y1="9" x2="15" y2="15" />
                </svg>
                <span
                  >Desconectado do seu contexto real de deslocamento, clima e
                  localização.</span
                >
              </div>
            </div>
          </div>

          <div class="concept-card pally-card">
            <h3 class="concept-card-title">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <polygon points="12 2 2 7 12 12 22 7 12 2" />
                <polyline points="2 17 12 22 22 17" />
                <polyline points="2 12 12 17 22 12" />
              </svg>
              Pally — O Companheiro de Viagem
            </h3>
            <div class="concept-body">
              <div class="concept-item">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#10B981"
                  stroke-width="2"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span
                  ><strong>Visual de um toque:</strong> Apresenta 3 cards de
                  sugestões com atalhos diretos para você navegar ou abrir seus
                  apps de reserva.</span
                >
              </div>
              <div class="concept-item">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#10B981"
                  stroke-width="2"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span
                  ><strong>Sugestões contextualizadas:</strong> Recomendações
                  inteligentes baseadas no clima atual, horário e localização no
                  destino.</span
                >
              </div>
              <div class="concept-item">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="#10B981"
                  stroke-width="2"
                >
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span
                  ><strong>Planejamento assistido:</strong> Facilita a adaptação
                  do seu roteiro sugerindo novas alternativas de forma
                  proativa.</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==========================================================================
       4. Features Section (Empathetic and Contextual B2C features)
       ========================================================================== -->
    <section class="features-section" id="features">
      <div class="container">
        <div class="section-header">
          <span class="section-tagline">Funcionalidades</span>
          <h2>Tudo o que sua viagem precisa</h2>
          <p class="section-description">
            A tecnologia mais avançada de planejamento assistido e suporte,
            compactada em uma interface leve e inovadora.
          </p>
        </div>

        <div class="features-grid">
          <!-- Feature 1 -->
          <div class="glass-card feature-card">
            <div class="feature-icon-wrapper">
              <svg
                viewBox="0 0 24 24"
                width="24"
                height="24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"
                />
                <path d="M12 6v6l4 2" />
              </svg>
            </div>
            <h3 class="feature-title">Roteiros Inteligentes</h3>
            <p class="feature-desc">
              Planeje sua viagem de forma inteligente. Pally sugere ajustes no
              seu roteiro com base em novos horários, clima ou trânsito local.
            </p>
          </div>

          <!-- Feature 2 -->
          <div class="glass-card feature-card purple-theme">
            <div class="feature-icon-wrapper">
              <svg
                viewBox="0 0 24 24"
                width="24"
                height="24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                />
              </svg>
            </div>
            <h3 class="feature-title">Assistente Contextual</h3>
            <p class="feature-desc">
              Sugestões proativas e oportunas. Pally entende o que acontece ao
              seu redor e oferece atalhos rápidos para facilitar suas decisões.
            </p>
          </div>

          <!-- Feature 3 -->
          <div class="glass-card feature-card">
            <div class="feature-icon-wrapper">
              <svg
                viewBox="0 0 24 24"
                width="24"
                height="24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                <rect x="7" y="7" width="3" height="3" />
                <rect x="14" y="7" width="3" height="3" />
                <rect x="7" y="14" width="3" height="3" />
                <rect x="14" y="14" width="3" height="3" />
              </svg>
            </div>
            <h3 class="feature-title">Cards Contextuais</h3>
            <p class="feature-desc">
              Os 3 cards exibidos refletem o que está aberto, o clima do momento
              e suas preferências pessoais no destino.
            </p>
          </div>

          <!-- Feature 4 -->
          <div class="glass-card feature-card purple-theme">
            <div class="feature-icon-wrapper">
              <svg
                viewBox="0 0 24 24"
                width="24"
                height="24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z" />
                <path d="M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z" />
              </svg>
            </div>
            <h3 class="feature-title">Inteligência Empática</h3>
            <p class="feature-desc">
              Pally se adapta ao seu ritmo de viagem. Se você prefere dias
              tranquilos ou cheios de atividades, as sugestões acompanham seu
              estilo.
            </p>
          </div>

          <!-- Feature 5 -->
          <div class="glass-card feature-card">
            <div class="feature-icon-wrapper">
              <svg
                viewBox="0 0 24 24"
                width="24"
                height="24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </div>
            <h3 class="feature-title">Funcionamento Offline</h3>
            <p class="feature-desc">
              Mapas e sugestões salvas continuam acessíveis mesmo se você perder
              a conexão com a internet durante os passeios.
            </p>
          </div>

          <!-- Feature 6 -->
          <div class="glass-card feature-card purple-theme">
            <div class="feature-icon-wrapper">
              <svg
                viewBox="0 0 24 24"
                width="24"
                height="24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
              </svg>
            </div>
            <h3 class="feature-title">Jornadas Multicidades</h3>
            <p class="feature-desc">
              O app aprende com suas escolhas anteriores para sugerir novos
